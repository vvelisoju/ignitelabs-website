{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["DOM", "ES2022"],
    "jsx": "react-jsx",
    "types": ["react"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "sourceMap": true,

    /* relax the checks producing the build errors you showed */
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": false,
    "verbatimModuleSyntax": false,

    /* path alias so imports like "@/hooks/..." resolve to "src/hooks/..." */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    /* don't emit declaration files from this top-level config */
    "declaration": false,
    "declarationMap": false
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
